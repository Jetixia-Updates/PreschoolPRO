# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://neondb_owner:xxxx@ep-xxxx-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
DIRECT_DATABASE_URL="postgresql://neondb_owner:xxxx@ep-xxxx-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Redis (optional - for caching and sessions)
REDIS_URL="redis://localhost:6379"

# OpenAI (for AI features)
OPENAI_API_KEY="sk-your-api-key-here"

# Email (optional - for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-password"
SMTP_FROM="noreply@eduplatform.com"

# File Storage (optional)
STORAGE_PROVIDER="local"
